<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Full-screen image -->
    <ImageView
        android:id="@+id/ivResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="Result" />

    <!-- Bounding box overlay -->
    <com.example.testerapigoogle.BoundingBoxOverlay
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- TOP: Panel identification card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_gravity="top"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#E6003865">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● PANEL IDENTIFIED"
                    android:textColor="#3DCD58"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333D65" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/tvPanelType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp" />

                <TextView
                    android:id="@+id/tvPanelSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="#B0C4DE"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- BOTTOM SHEET: Buttons + Notes + Warnings -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F0111827"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="80dp"
        app:behavior_hideable="false"
        app:behavior_draggable="true">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:background="#555555"
            android:backgroundTint="#555555" />

        <!-- Buttons — always visible in peek state -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQr"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:text="QR"
                android:textAllCaps="false"
                android:visibility="gone"
                app:backgroundTint="#FF6F00"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_menu_zoom" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetake"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Retake"
                android:textAllCaps="false"
                app:backgroundTint="@color/schneider_green_dark"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveReport"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Save"
                android:textAllCaps="false"
                app:backgroundTint="#CC003865"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_menu_save" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareResult"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Share"
                android:textAllCaps="false"
                android:visibility="gone"
                app:backgroundTint="@color/schneider_green_dark"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_menu_share" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegisterPanel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Reg Panel"
                android:textAllCaps="false"
                app:backgroundTint="#CC1565C0"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_menu_add" />

        </LinearLayout>

        <!-- Notes -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="6dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E6111827">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="6dp"
                    android:text="📋  INSPECTION NOTES"
                    android:textColor="#90CAF9"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1E3A5F" />

                <TextView
                    android:id="@+id/tvNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="10dp"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Safety warnings -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWarnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E67B1818">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚠  SAFETY WARNINGS"
                        android:textColor="#FFD600"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.10" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#5C1A1A" />

                <TextView
                    android:id="@+id/tvWarnings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="10dp"
                    android:textColor="#FFCDD2"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
