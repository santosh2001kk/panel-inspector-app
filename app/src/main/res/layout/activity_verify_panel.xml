<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Panel Verification"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:paddingTop="16dp"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Take a photo of the panel in front of you to confirm it matches the risk analysis."
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:paddingBottom="16dp" />

    <!-- Two photos side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <!-- Reference image -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📸 Risk Analysis Photo"
                android:textColor="#64B5F6"
                android:textSize="12sp"
                android:paddingBottom="6dp" />

            <ImageView
                android:id="@+id/ivReference"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#1E293B"
                android:contentDescription="Reference panel photo" />
        </LinearLayout>

        <!-- Worker photo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📷 Your Current Photo"
                android:textColor="#64B5F6"
                android:textSize="12sp"
                android:paddingBottom="6dp" />

            <ImageView
                android:id="@+id/ivWorkerPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#1E293B"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Worker photo" />
        </LinearLayout>

    </LinearLayout>

    <!-- Result -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- Progress -->
    <LinearLayout
        android:id="@+id/layoutProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="12dp">

        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="#64B5F6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Asking AI to compare panels..."
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:paddingTop="8dp" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Back"
            android:textColor="#FFFFFF"
            app:strokeColor="#475569" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTakePhoto"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Take Photo"
            android:textAllCaps="false"
            app:backgroundTint="#1565C0"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerifyNow"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Verify"
            android:textAllCaps="false"
            android:enabled="false"
            app:backgroundTint="#B71C1C"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
